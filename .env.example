# QuantAgent — Environment Configuration
# Copy this file to .env and fill in your credentials

# ─── Market Data ────────────────────────────────────────────────────────────
POLYGON_API_KEY=your_polygon_api_key
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets
COINGECKO_API_KEY=your_coingecko_api_key
FINNHUB_API_KEY=your_finnhub_api_key
TAVILY_API_KEY=your_tavily_api_key          # optional — web news search

# ─── LLM: Local (LM Studio) ─────────────────────────────────────────────────
# Load Qwen2.5-Coder-7B-Instruct (or any OpenAI-compatible model) in LM Studio
LLM_PROVIDER=local
LLM_LOCAL_URL=http://localhost:1234/v1
LLM_LOCAL_MODEL=qwen2.5-coder-7b-instruct
LLM_LOCAL_TIMEOUT=120
LLM_MAX_TOKENS=300

# ─── LLM: Anthropic Claude (uncomment to use instead of local) ──────────────
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-your_key_here

# ─── System ─────────────────────────────────────────────────────────────────
DASHBOARD_PORT=8765
SCAN_INTERVAL_SECONDS=60
WATCHLIST_SIZE=150
MAX_AGENT_WORKERS=6
LOG_LEVEL=INFO

# ─── Markets ────────────────────────────────────────────────────────────────
ENABLE_US_STOCKS=true
ENABLE_PENNY_STOCKS=true
ENABLE_CRYPTO=true
ENABLE_INTERNATIONAL=true
ENABLE_ETF=true

# ─── Alerts (optional) ──────────────────────────────────────────────────────
ALERT_EMAIL_TO=you@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_app_password

# ─── Dashboard Auth (optional) ──────────────────────────────────────────────
# DASHBOARD_API_KEY=your_secret_key
